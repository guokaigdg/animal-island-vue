{
    "name": "animal-island-vue",
    "version": "0.2.0",
    "description": "A nature-inspired Vue 3 component library, powered by Less + CSS Variables.",
    "type": "module",
    "main": "dist/cjs/index.cjs",
    "module": "dist/es/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/es/index.js",
            "require": "./dist/cjs/index.cjs"
        },
        "./style": {
            "types": "./dist/style.d.ts",
            "default": "./dist/index.css"
        },
        "./dist/index.css": "./dist/index.css"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "sideEffects": [
        "**/*.css",
        "**/*.vue"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/guokaigdg/animal-island-vue"
    },
    "author": "guokaigdg",
    "scripts": {
        "dev": "vite --config vite.config.docs.ts",
        "build": "vue-tsc --noEmit -p tsconfig.build.json && vite build",
        "build:demo": "vite build --config vite.config.docs.ts",
        "preview:docs": "vite preview --config vite.config.docs.ts",
        "test": "vitest",
        "typecheck": "vue-tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "vue": ">=3.4.0"
    },
    "dependencies": {
        "@fontsource/noto-sans-sc": "^5.2.9",
        "@fontsource/nunito": "^5.2.7",
        "modern-screenshot": "^4.6.0"
    },
    "devDependencies": {
        "@laynezh/vite-plugin-lib-assets": "^2.1.3",
        "@types/node": "^25.5.2",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/test-utils": "^2.4.6",
        "gh-pages": "^6.3.0",
        "jsdom": "^25.0.1",
        "less": "^4.6.4",
        "typescript": "^5.7.3",
        "vite": "^7.3.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^2.1.8",
        "vue": "^3.5.13",
        "vue-tsc": "^2.2.0"
    },
    "keywords": [
        "vue",
        "vue3",
        "component-library",
        "ui",
        "typescript",
        "less",
        "animal-island-vue",
        "nature"
    ],
    "license": "MIT"
}
